    },
    {
      "id": "YRU6A1NMna82QEasyGyiH",
      "type": "text",
      "x": 40.35110631351699,
      "y": 9890.926540941266,
      "width": 480.02386474609375,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2X",
      "roundness": null,
      "seed": 955982983,
      "version": 172,
      "versionNonce": 1313501001,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775317381612,
      "link": null,
      "locked": false,
      "text": "Algorithm :\n\n*prev = *next_node = NULL\n*temp = *head",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Algorithm :\n\n*prev = *next_node = NULL\n*temp = *head",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5iZTnXSKCvbVr-QtMkkY-",
      "type": "text",
      "x": 95.55371456736123,
      "y": 10081.82408412099,
      "width": 516.707763671875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2Z",
      "roundness": null,
      "seed": 1394835143,
      "version": 259,
      "versionNonce": 867147305,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775317381612,
      "link": null,
      "locked": false,
      "text": "while(temp != NULL){\n    // Store next\n    next_node = temp -> next",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "while(temp != NULL){\n    // Store next\n    next_node = temp -> next",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C5yysvf2tLQuQ1Ges4sMM",
      "type": "text",
      "x": 103.42387265660705,
      "y": 10202.371684115706,
      "width": 694.9437255859375,
      "height": 405,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2a",
      "roundness": null,
      "seed": 1399199305,
      "version": 292,
      "versionNonce": 2099947463,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "Qh8Gfn-UX9LZJVFFdRxRs",
          "type": "arrow"
        }
      ],
      "updated": 1775318067284,
      "link": null,
      "locked": false,
      "text": "// Reverser the current node`s pointer\ntemp -> next = prev;\n\n// Move the pointer one potion forward\n\nprev= temp\ntemp = next_node\n}\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// Reverser the current node`s pointer\ntemp -> next = prev;\n\n// Move the pointer one potion forward\n\nprev= temp\ntemp = next_node\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
