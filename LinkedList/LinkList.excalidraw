    {
      "id": "qZ5Ed2qfUFPd7KwBoIMsi",
      "type": "text",
      "x": 235.81028174091034,
      "y": 4060.053902453739,
      "width": 1058.61572265625,
      "height": 495,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1S",
      "roundness": null,
      "seed": 437862902,
      "version": 492,
      "versionNonce": 167067062,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774889564635,
      "link": null,
      "locked": false,
      "text": ">> Get the new Node . i.e newNode . \n>> Ensure that the position is in between Head and Tail .\n    If not , specify that position INVALID .\n\n>> Store the starting Address in temp aad previous pointer.\n    then traverse the temp pointer to the spicified position \n    follow by previous  pointer \n\n>> After reaching the specified position :\n            >>> previous -> next = newNode;\n            >>> newNode -> next = temp ;",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": ">> Get the new Node . i.e newNode . \n>> Ensure that the position is in between Head and Tail .\n    If not , specify that position INVALID .\n\n>> Store the starting Address in temp aad previous pointer.\n    then traverse the temp pointer to the spicified position \n    follow by previous  pointer \n\n>> After reaching the specified position :\n            >>> previous -> next = newNode;\n            >>> newNode -> next = temp ;",
      "autoResize": true,
      "lineHeight": 1.25
    },
