    {
      "id": "jmZncnyWCT1DreppxgKHU",
      "type": "text",
      "x": 109.02911821218879,
      "y": 3016.7368675007765,
      "width": 680.6889038085938,
      "height": 273.30094542356744,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0k",
      "roundness": null,
      "seed": 369302710,
      "version": 462,
      "versionNonce": 2034743798,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774888091515,
      "link": null,
      "locked": false,
      "text": ">> Get the new Node ; newNode \n>> If the list is empty ; Head = newNode; \n>>  If the list is not empty :\n            >>  temp = head \n            >>  while ( temp -> next != NULL) \n                            temp = temp -> next ;\n                 temp -> next = newNode ;",
      "fontSize": 31.234393762693426,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": ">> Get the new Node ; newNode \n>> If the list is empty ; Head = newNode; \n>>  If the list is not empty :\n            >>  temp = head \n            >>  while ( temp -> next != NULL) \n                            temp = temp -> next ;\n                 temp -> next = newNode ;",
      "autoResize": true,
      "lineHeight": 1.25
    },
