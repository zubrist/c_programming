      "index": "aXG",
      "roundness": null,
      "seed": 826077251,
      "version": 421,
      "versionNonce": 188982755,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780765012954,
      "link": null,
      "locked": false,
      "text": "selectionSort(array, size)\n  for i from 0 to size - 1 do\n    set i as the index of the current minimum\n    for j from i + 1 to size - 1 do\n      if array[j] < array[current minimum]\n        set j as the new current minimum index\n    if current minimum is not i\n      swap array[i] with array[current minimum]\nend selectionSort",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "selectionSort(array, size)\n  for i from 0 to size - 1 do\n    set i as the index of the current minimum\n    for j from i + 1 to size - 1 do\n      if array[j] < array[current minimum]\n        set j as the new current minimum index\n    if current minimum is not i\n      swap array[i] with array[current minimum]\nend selectionSort",
      "autoResize": true,
      "lineHeight": 1.25
    },
