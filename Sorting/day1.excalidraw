    {
      "id": "tZgAh2vh9GtuXNPRgMfMd",
      "type": "text",
      "x": 330.0332163531595,
      "y": 2725.7111385088047,
      "width": 450.2596130371094,
      "height": 225,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
