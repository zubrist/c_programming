      "boundElements": null,
      "updated": 1780764442257,
      "link": null,
      "locked": false,
      "text": "Step 2: compare the minimum with the second element , if the second element\n            is smaller than minimum , update minimum i.e set second element as minimum",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 2: compare the minimum with the second element , if the second element\n            is smaller than minimum , update minimum i.e set second element as minimum",
      "autoResize": true,
      "lineHeight": 1.25
    },
