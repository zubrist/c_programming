      "isDeleted": false,
      "boundElements": [],
      "updated": 1775926821915,
      "link": null,
      "locked": false,
      "text": "1) ) d * ) b - a ( ( / ) C * ) b + a ((\n\n2) ( d * ( b -a ) ) / ( C * ( b + a ))\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) ) d * ) b - a ( ( / ) C * ) b + a ((\n\n2) ( d * ( b -a ) ) / ( C * ( b + a ))\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
