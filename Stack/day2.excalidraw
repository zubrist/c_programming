      "isDeleted": false,
      "boundElements": null,
      "updated": 1776530956401,
      "link": null,
      "locked": false,
      "text": "stack overflow occurs when an attempt is made to POP or access an element \nfrom a stack that is currently EMPTY.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "stack overflow occurs when an attempt is made to POP or access an element \nfrom a stack that is currently EMPTY.",
