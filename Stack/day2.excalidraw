      "boundElements": null,
      "updated": 1776530924292,
      "link": null,
      "locked": false,
      "text": "stack overflow occurs when an attempt is made to PUSH an element onto \na stack that is already FULL. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "stack overflow occurs when an attempt is made to PUSH an element onto \na stack that is already FULL. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
