      "index": "a5",
      "roundness": null,
      "seed": 1645492878,
      "version": 200,
      "versionNonce": 1476734098,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776528692373,
      "link": null,
      "locked": false,
      "text": "step 7 : After the entire expression is scanned : \n                pop any remaning operator from the stack and append to the \n                output string .",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "step 7 : After the entire expression is scanned : \n                pop any remaning operator from the stack and append to the \n                output string .",
      "autoResize": true,
      "lineHeight": 1.25
    },
