    {
      "id": "MzMwpMzz5xsbN_hCbU_Yw",
      "type": "text",
      "x": 340.2354728663264,
      "y": 2019.4693678841975,
      "width": 670.7796630859375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 922640530,
      "version": 206,
      "versionNonce": 1900545038,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776529294026,
      "link": null,
      "locked": false,
      "text": "Input : The new item ITEM is yo be pushed to the stack\noutput : A stack with newly pushed ITEM at the TOP of the stack\nData Structure : An array A with TOP as the pointer ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Input : The new item ITEM is yo be pushed to the stack\noutput : A stack with newly pushed ITEM at the TOP of the stack\nData Structure : An array A with TOP as the pointer ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oMIfL1YBXhhILBVddGdmX",
      "type": "text",
      "x": 338.9413564372595,
      "y": 2115.2339836351475,
      "width": 311.89984130859375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 425105102,
      "version": 118,
      "versionNonce": 1144131922,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776529498033,
      "link": null,
      "locked": false,
      "text": "Steps:\n        If the TOP >= SIZE\n                print \"stack is full\"\n\n         Else \n                TOP + TOP +1 \n                A[TOP] = ITEM",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Steps:\n        If the TOP >= SIZE\n                print \"stack is full\"\n\n         Else \n                TOP + TOP +1 \n                A[TOP] = ITEM",
      "autoResize": true,
      "lineHeight": 1.25
    },
