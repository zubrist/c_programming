      "isDeleted": false,
      "boundElements": null,
      "updated": 1773758995906,
      "link": null,
      "locked": false,
      "text": "base address = B \nWeight = w i.e 4 , 1, 8 \n\ntarget [i,j] ...",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "base address = B \nWeight = w i.e 4 , 1, 8 \n\ntarget [i,j] ...",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LDCfPQjqzcOTWCZztTrQg",
      "type": "text",
      "x": 80.84081863054456,
      "y": 1432.985664105339,
      "width": 918.1796264648438,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 1403729805,
      "version": 209,
      "versionNonce": 805651853,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773759178176,
      "link": null,
      "locked": false,
      "text": "A[10][10] ,  M= 10 , N= 10 \nB = 3000 , w = int = 4 , target A[2][3] . i =2 , j= 3\n\n    Row major \n                       Adress = B + w * [ i * N + j ]\n\n     Column major \n                       Adress = B + w * [ j * M + i ]",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A[10][10] ,  M= 10 , N= 10 \nB = 3000 , w = int = 4 , target A[2][3] . i =2 , j= 3\n\n    Row major \n                       Adress = B + w * [ i * N + j ]\n\n     Column major \n                       Adress = B + w * [ j * M + i ]",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fuvFxgTdFGeqpufevcFmD",
      "type": "text",
      "x": 81.55882387177519,
      "y": 1956.3794957145556,
      "width": 1240.7037353515625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b05",
      "roundness": null,
      "seed": 241642861,
      "version": 164,
      "versionNonce": 1582931171,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773759639122,
      "link": null,
      "locked": false,
      "text": "when  array start position is assumed \n     { i * N + j }  ==>  { (i - assumed value) * N + (j - assumed value)} \n    ",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "when  array start position is assumed \n     { i * N + j }  ==>  { (i - assumed value) * N + (j - assumed value)} \n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
