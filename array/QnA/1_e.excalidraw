    {
      "id": "Im7wxjbUpnhrFYbjJM49c",
      "type": "text",
      "x": 64.68668667282532,
      "y": 1138.6214817646774,
      "width": 391.391845703125,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
