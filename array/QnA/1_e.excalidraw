      "isDeleted": false,
      "boundElements": null,
      "updated": 1773760754751,
      "link": null,
      "locked": false,
      "text": "Number of rows( M ) = ( Upper Bound - Lower Bound +1 ) = 8 - 2 + 1 = 7",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Number of rows( M ) = ( Upper Bound - Lower Bound +1 ) = 8 - 2 + 1 = 7",
      "autoResize": true,
      "lineHeight": 1.25
    },
