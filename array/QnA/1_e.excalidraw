      "locked": false,
      "text": "This notation indiagtes the lower and upper bounds for the rows and cols\n\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This notation indiagtes the lower and upper bounds for the rows and cols\n\n",
