    {
      "id": "aJOQu6L_kuxtnbgId3SNa",
      "type": "text",
      "x": 44.340399047851406,
      "y": 7807.59327388384,
      "width": 366.41973876953125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
