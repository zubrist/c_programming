      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973458459,
      "link": null,
      "locked": false,
      "text": "A hash collision or hash clash is a situation that occurs when two distinct inputs\ninto a hash function",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A hash collision or hash clash is a situation that occurs when two distinct inputs into a hash function",
      "autoResize": false,
      "lineHeight": 1.25
    },
