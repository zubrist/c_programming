      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973079043,
      "link": null,
      "locked": false,
      "text": "The properties of a good hash function are-",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The properties of a good hash function are-",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-qAGhLrCup3BU5snpniUl",
      "type": "text",
      "x": 246.94043186950677,
      "y": 3313.9631253242515,
      "width": 269.1997985839844,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
      "roundness": null,
      "seed": 1204824135,
      "version": 126,
      "versionNonce": 1697413737,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973114521,
      "link": null,
      "locked": false,
      "text": "It is efficiently computable.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is efficiently computable.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "H9btGxzuXguNsv6r7q1xH",
      "type": "text",
      "x": 248.90040806579583,
      "y": 3349.7131863594077,
      "width": 357.1397705078125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1a",
      "roundness": null,
      "seed": 2061149097,
      "version": 89,
      "versionNonce": 1887858183,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973117711,
      "link": null,
      "locked": false,
      "text": "It minimizes the number of collisions.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It minimizes the number of collisions.",
