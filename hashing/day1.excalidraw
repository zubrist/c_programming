    {
      "id": "XjPcYhZFjMueehLvprVj3",
      "type": "text",
      "x": 55.23035862731888,
      "y": 4256.793073490147,
      "width": 571.6795654296875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1v",
      "roundness": null,
      "seed": 147846025,
      "version": 112,
      "versionNonce": 1148020935,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973841135,
      "link": null,
      "locked": false,
      "text": "This uses an array as the primary hash table, except that",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This uses an array as the primary hash table, except that",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XhQcDehZ4BL-4QJRV4y_P",
      "type": "text",
      "x": 632.3105283050533,
      "y": 4257.233075931554,
      "width": 400.1797180175781,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1w",
      "roundness": null,
      "seed": 587310471,
      "version": 156,
      "versionNonce": 92065769,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973902470,
      "link": null,
      "locked": false,
      "text": "the array is an array of lists of entries, \neach list initially being empty.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "the array is an array of lists of entries, \neach list initially being empty.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "eufom1s2qz5vccIQ-jzGK",
      "type": "text",
      "x": 63.55537083435013,
      "y": 4323.038099124913,
      "width": 1075.57470703125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1x",
      "roundness": null,
      "seed": 1132108393,
      "version": 222,
      "versionNonce": 508164615,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973923197,
      "link": null,
      "locked": false,
      "text": "If in a set of elements, if an element hashes to the same value as that of an already inserted element then",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If in a set of elements, if an element hashes to the same value as that of an already inserted element then",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "96OPFc-kGZ0lR7sUT3f-e",
      "type": "text",
      "x": 70.9404721527095,
      "y": 4371.413221195226,
      "width": 780.2594604492188,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1y",
      "roundness": null,
      "seed": 987847847,
      "version": 128,
      "versionNonce": 881960361,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781973959464,
      "link": null,
      "locked": false,
      "text": "In separate chaining ,each slot of the bucket array is a pointer to a linked list\nthat contains key-value pairs that are hashed to the same location.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In separate chaining ,each slot of the bucket array is a pointer to a linked list that contains key-value pairs that are hashed to the same location.",
      "autoResize": false,
      "lineHeight": 1.25
    },
