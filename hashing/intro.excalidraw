      "text": "hash funtion : h(k) =  K mod 10 \n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "hash funtion : h(k) =  K mod 10 \n\n",
      "autoResize": true,
