    {
      "id": "BY758uq_yXeOI6h2jQtam",
      "type": "text",
      "x": 275,
      "y": 1741,
      "width": 490.07977294921875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
