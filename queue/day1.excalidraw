      "seed": 2133830111,
      "version": 291,
      "versionNonce": 92443665,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777134521192,
      "link": null,
      "locked": false,
      "text": "Algo:\n        step1: if Rear = Max-1 : then\n                    print(\"queue overflow\")\n\n        step2: else , Read the NUM to be inserted \n        step3: Rear = Rear +1\n        step4: Q[Rear] = NUM \n\n        step5 : if Front = -1 then\n                    Front = Front + 1",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Algo:\n        step1: if Rear = Max-1 : then\n                    print(\"queue overflow\")\n\n        step2: else , Read the NUM to be inserted \n        step3: Rear = Rear +1\n        step4: Q[Rear] = NUM \n\n        step5 : if Front = -1 then\n                    Front = Front + 1",
      "autoResize": true,
      "lineHeight": 1.25
    },
