      "isDeleted": false,
      "boundElements": null,
      "updated": 1777131995973,
      "link": null,
      "locked": false,
      "text": "5) Queue follows FIFO(first in first out)  rule",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5) Queue follows FIFO(first in first out)  rule",
      "autoResize": true,
      "lineHeight": 1.25
    },
