      "seed": 928010097,
      "version": 52,
      "versionNonce": 1046057745,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777131769349,
      "link": null,
      "locked": false,
      "text": "1) Queue is a non-primitive linear data structure ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) Queue is a non-primitive linear data structure ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rwmf-Vp_GkArbR-MwnoX8",
      "type": "text",
      "x": 269.60003662109375,
      "y": 361.4000244140625,
      "width": 760.01953125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 1467240127,
      "version": 328,
      "versionNonce": 961255345,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777131961773,
      "link": null,
      "locked": false,
      "text": "2) Insertion of an element take place at one end, and deletion of an element \n    take place in the other end .\n\n3) the end at which the deletion of an element take place is called FRONT\n4)  the end at which the insertion of an element take place is called REAR",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2) Insertion of an element take place at one end, and deletion of an element \n    take place in the other end .\n\n3) the end at which the deletion of an element take place is called FRONT\n4)  the end at which the insertion of an element take place is called REAR",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oLhGsi7cAre_CsDiBzRxT",
      "type": "text",
      "x": 275,
      "y": 504,
      "width": 454.1796569824219,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
