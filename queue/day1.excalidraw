      "updated": 1777134488551,
      "link": null,
      "locked": false,
      "text": "algo:\n        step1: If Front = -1 then\n                    print (\"Queue Underflow\")\n        step2: else,\n                       NUM =  Q[Front]\n                       print( deleteded NUM)\n        step3: Front = Front + 1\n        \n        Step4: if Front> Rear then\n                    Front = Rear = -1 ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "algo:\n        step1: If Front = -1 then\n                    print (\"Queue Underflow\")\n        step2: else,\n                       NUM =  Q[Front]\n                       print( deleteded NUM)\n        step3: Front = Front + 1\n        \n        Step4: if Front> Rear then\n                    Front = Rear = -1 ",
      "autoResize": true,
      "lineHeight": 1.25
    },
