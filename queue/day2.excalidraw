      "updated": 1777740087566,
      "link": null,
      "locked": false,
      "text": "Else: \n        val= array[rear];\n\n        if front == rear // last element\n                front = rear = -1 ;\n        else if rear = 0\n                rear = size-1;\n\n        else: \n                rear = rear -1 ;",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Else: \n        val= array[rear];\n\n        if front == rear // last element\n                front = rear = -1 ;\n        else if rear = 0\n                rear = size-1;\n\n        else: \n                rear = rear -1 ;",
      "autoResize": true,
      "lineHeight": 1.25
    },
