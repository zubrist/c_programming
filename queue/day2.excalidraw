      "isDeleted": false,
      "boundElements": null,
      "updated": 1777738890384,
      "link": null,
      "locked": false,
      "text": "Else:\n       If front == -1: // first elm\n            front = rear = 0\n       else if rear = size-1\n            rear = 0\n       else:\n            rear = rear+1\n       arr[rear] = value",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Else:\n       If front == -1: // first elm\n            front = rear = 0\n       else if rear = size-1\n            rear = 0\n       else:\n            rear = rear+1\n       arr[rear] = value",
      "autoResize": true,
      "lineHeight": 1.25
    },
