      "isDeleted": false,
      "boundElements": null,
      "updated": 1777739818773,
      "link": null,
      "locked": false,
      "text": "If front == -1 \n    print (\" Queue underflow\")\n\nElse:\n    val = array[front]\n\n    if front == rear : // last element\n        rear = frront == -1\n\n    else if front == size -1 \n            front = 0\n    else :\n            front =front + 1\n\n    retun val",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If front == -1 \n    print (\" Queue underflow\")\n\nElse:\n    val = array[front]\n\n    if front == rear : // last element\n        rear = frront == -1\n\n    else if front == size -1 \n            front = 0\n    else :\n            front =front + 1\n\n    retun val",
      "autoResize": true,
      "lineHeight": 1.25
    },
