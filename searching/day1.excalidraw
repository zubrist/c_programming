    {
      "id": "h_XwtVsxLyJYpeX6hEWXY",
      "type": "text",
      "x": 393.10406289870474,
      "y": 3706.6662630069272,
      "width": 361.6197509765625,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0s",
      "roundness": null,
      "seed": 307379659,
      "version": 376,
      "versionNonce": 603536939,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780206338238,
      "link": null,
      "locked": false,
      "text": "binarySearch( a[], low, high , target):\n        while ( low <= high) :\n            mid = (low+ high ) / 2\n            if ( a[mid] == target ) :\n                       reurn mid\n            else if a[mid] < target \n                       low = mid + 1\n             else :\n                    high = mid - 1\n         end of while loop\n\nreturn -1 ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "binarySearch( a[], low, high , target):\n        while ( low <= high) :\n            mid = (low+ high ) / 2\n            if ( a[mid] == target ) :\n                       reurn mid\n            else if a[mid] < target \n                       low = mid + 1\n             else :\n                    high = mid - 1\n         end of while loop\n\nreturn -1 ",
      "autoResize": true,
      "lineHeight": 1.25
    },
