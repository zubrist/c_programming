      "seed": 680451691,
      "version": 172,
      "versionNonce": 2025767685,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780203679991,
      "link": null,
      "locked": false,
      "text": "linearSearch( a[] , size, target)\n{\n    for i = 0 to n-1 :\n         if ( a[i] = target):\n            return i\n    end for \nreturn -1\n}\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "linearSearch( a[] , size, target)\n{\n    for i = 0 to n-1 :\n         if ( a[i] = target):\n            return i\n    end for \nreturn -1\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
