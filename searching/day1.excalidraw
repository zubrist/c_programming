    {
      "id": "UfjL9nHOBDbAtiE56pHXz",
      "type": "text",
      "x": 331.08981381939344,
      "y": 1641.9602690511535,
      "width": 305.6397399902344,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
