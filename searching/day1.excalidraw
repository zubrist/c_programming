      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 196504075,
      "version": 146,
      "versionNonce": 1973886725,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780203841883,
      "link": null,
      "locked": false,
      "text": "Step 1: Examine the array's searching item (Target value). \n\nStep 2: Comparing the search element to the array's first element. \n\nStep 3: If both elements match, the message \"Target element discovered\" ends the procedure. \n\nStep 4: In the absence of a match, look at the next member in the array to see if the search element is\nthere. \n\nStep 5: Repeat procedures 3 and 4 above until the searching (Target) item matches the array's last\nthing. \n\nStep 6: \"Element not found\" would be shown when the last component in your list does not match.",
      "fontSize": 17.397758860478636,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 1: Examine the array's searching item (Target value). \n\nStep 2: Comparing the search element to the array's first element. \n\nStep 3: If both elements match, the message \"Target element discovered\" ends the procedure. \n\nStep 4: In the absence of a match, look at the next member in the array to see if the search element is there. \n\nStep 5: Repeat procedures 3 and 4 above until the searching (Target) item matches the array's last thing. \n\nStep 6: \"Element not found\" would be shown when the last component in your list does not match.",
      "autoResize": false,
      "lineHeight": 1.25
    },
