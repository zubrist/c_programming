      "seed": 1409438674,
      "version": 190,
      "versionNonce": 1593902734,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780989364394,
      "link": null,
      "locked": false,
      "text": "Algo :\n\nvoid mergeSort( l, h){\n        \n            if ( l<h)\n                {\n                    MID = l+ h / 2\n\n                    mergeSort(l,mid)\n                    mergeSort( mid+1 , h)\n                    merge( A , l , h,k)\n                }\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Algo :\n\nvoid mergeSort( l, h){\n        \n            if ( l<h)\n                {\n                    MID = l+ h / 2\n\n                    mergeSort(l,mid)\n                    mergeSort( mid+1 , h)\n                    merge( A , l , h,k)\n                }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
