      "type": "text",
      "x": 319.899977501678,
      "y": 8365.643679539347,
      "width": 554.4996337890625,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
