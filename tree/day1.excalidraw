      "isDeleted": false,
      "boundElements": null,
      "updated": 1778386261248,
      "link": null,
      "locked": false,
      "text": "In a tree data structure, the root node is said to be at Level 0 and the children\nof root node are at Level 1 and the children of the nodes which are at Level 1\nwill be at Level 2 and so on",
      "fontSize": 20.73079064861965,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In a tree data structure, the root node is said to be at Level 0 and the children of root node are at Level 1 and the children of the nodes which are at Level 1 will be at Level 2 and so on",
      "autoResize": false,
      "lineHeight": 1.25
