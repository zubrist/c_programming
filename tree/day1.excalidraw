      "isDeleted": false,
      "boundElements": null,
      "updated": 1778385713603,
      "link": null,
      "locked": false,
      "text": "simple words, the node which has a link from its parent node is called as child\nnode.",
      "fontSize": 22.30772451059149,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "simple words, the node which has a link from its parent node is called as child node.",
