    },
    {
      "id": "RdwaFemgZY0kY6FZLE_6Z",
      "type": "text",
      "x": 255.21867605574232,
      "y": 774.4291923497728,
      "width": 850.6927490234375,
      "height": 48.870222212446876,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aK",
      "roundness": null,
      "seed": 1795638273,
      "version": 73,
      "versionNonce": 92717313,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778385523151,
      "link": null,
      "locked": false,
      "text": "In a tree data structure, the connecting link between any two nodes is called as EDGE. \nIn a tree with 'N' number of nodes there will be a maximum of 'N-1' number of edges.",
      "fontSize": 19.54808888497875,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In a tree data structure, the connecting link between any two nodes is called as EDGE. \nIn a tree with 'N' number of nodes there will be a maximum of 'N-1' number of edges.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Dfsejhy6ZXqii7szfGKNG",
      "type": "text",
      "x": 260.86334613940215,
      "y": 854.6644708710417,
      "width": 74.43194580078125,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
