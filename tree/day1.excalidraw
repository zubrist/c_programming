      "link": null,
      "locked": false,
      "text": "In a tree data structure, nodes other than leaf nodes are called as Internal Nodes. ",
      "fontSize": 21.80598152735874,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In a tree data structure, nodes other than leaf nodes are called as Internal Nodes. ",
