      "seed": 377569255,
      "version": 488,
      "versionNonce": 1704490823,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778948074064,
      "link": null,
      "locked": false,
      "text": "Algorithm:\n\nUntill all nodes are traversed- \nstep1: Recursively traverse left subtree\nstep2: recursively traverse right subtree\nStep3: Visit the root node\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Algorithm:\n\nUntill all nodes are traversed- \nstep1: Recursively traverse left subtree\nstep2: recursively traverse right subtree\nStep3: Visit the root node\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ncb5qzdfjkflZGCWu9GJ6",
      "type": "text",
      "x": 215.6996526038635,
      "y": 3898.6744874108795,
      "width": 320.31976318359375,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1J",
      "roundness": null,
      "seed": 608086791,
      "version": 723,
      "versionNonce": 711421639,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778948060005,
      "link": null,
      "locked": false,
      "text": "void postorder(tree_pointer ptr)\n{\nif (ptr)\n    {\n\n    postorder(ptr-> left_child);\n    postorder(ptr-> right_child);\n    printf(\"%d\", ptr-> data);\n}\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void postorder(tree_pointer ptr)\n{\nif (ptr)\n    {\n\n    postorder(ptr-> left_child);\n    postorder(ptr-> right_child);\n    printf(\"%d\", ptr-> data);\n}\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
