    {
      "id": "p4hX4tq01OWe77C6TKFSF",
      "type": "text",
      "x": 249.7422974465158,
      "y": 2820.082827631997,
      "width": 394.19970703125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 1034696681,
      "version": 466,
      "versionNonce": 2001566535,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778948000047,
      "link": null,
      "locked": false,
      "text": "Algorithm:\n\nUntill all nodes are traversed- \nStep1: Visit the root node\nstep2: Recursively traverse left subtree\nstep3: recursively traverse right subtree",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Algorithm:\n\nUntill all nodes are traversed- \nStep1: Visit the root node\nstep2: Recursively traverse left subtree\nstep3: recursively traverse right subtree",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DlucqC6V-zQVuNn28ykjE",
      "type": "text",
      "x": 245.24763414398035,
      "y": 2987.781349122314,
      "width": 304.97979736328125,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0K",
      "roundness": null,
      "seed": 823087817,
      "version": 408,
      "versionNonce": 148632999,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778948001413,
      "link": null,
      "locked": false,
      "text": "void preorder(tree_pointer ptr)\n{\nif (ptr)\n    {\n    printf(\"%d\", ptr-> data);\n    preorder(ptr-> left_child);\n    preorder(ptr-> right_child);\n    }\n}\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void preorder(tree_pointer ptr)\n{\nif (ptr)\n    {\n    printf(\"%d\", ptr-> data);\n    preorder(ptr-> left_child);\n    preorder(ptr-> right_child);\n    }\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
