      "text": "In-Order Traversal",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In-Order Traversal",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hdAeH02Bd9n2_sHJurk81",
      "type": "text",
      "x": 286.0776485452433,
      "y": 1881.758479057731,
      "width": 394.19970703125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 554248871,
      "version": 230,
      "versionNonce": 1552356647,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778946472884,
      "link": null,
      "locked": false,
      "text": "Algorithm:\n\nUntill all nodes are traversed- \nStep1: Recursively traverse left subtree\nstep2: Visit the root node\nstep3: recursively traverse right subtree",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Algorithm:\n\nUntill all nodes are traversed- \nStep1: Recursively traverse left subtree\nstep2: Visit the root node\nstep3: recursively traverse right subtree",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qo6r0qmir4vXJ5uT8HYwU",
      "type": "text",
      "x": 284.93719246377947,
      "y": 2064.709111649733,
      "width": 291.059814453125,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ag",
      "roundness": null,
      "seed": 1408974279,
      "version": 243,
      "versionNonce": 83268167,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778947334878,
      "link": null,
      "locked": false,
      "text": "void inorder(tree_pointer ptr)\n{\nif (ptr)\n    {\n    inorder(ptr-> left_child);\n    printf(\"%d\", ptr-> data);\n    inorder(ptr-> right_child);\n    }\n}\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void inorder(tree_pointer ptr)\n{\nif (ptr)\n    {\n    inorder(ptr-> left_child);\n    printf(\"%d\", ptr-> data);\n    inorder(ptr-> right_child);\n    }\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
