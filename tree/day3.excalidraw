    {
      "id": "JpRmZhag20_-2-OBUy9m-",
      "type": "text",
      "x": 421.1695056292384,
      "y": 2832.7724216808824,
      "width": 460.9597473144531,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 437741745,
      "version": 393,
      "versionNonce": 720485745,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779725900953,
      "link": null,
      "locked": false,
      "text": "Three Cases:\n\n1) the deleting Node is a leaf node\n        - Delete it immefiately \n\n2) the deleting node has one child\n        - remove the node and replace with the \n            deleting node`s child \n\n3) the deleting node has two child \n        - find largest value in left subtree or\n        - find the smallest in the right sub tree \n        - replavce with deleting node ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Three Cases:\n\n1) the deleting Node is a leaf node\n        - Delete it immefiately \n\n2) the deleting node has one child\n        - remove the node and replace with the \n            deleting node`s child \n\n3) the deleting node has two child \n        - find largest value in left subtree or\n        - find the smallest in the right sub tree \n        - replavce with deleting node ",
      "autoResize": true,
      "lineHeight": 1.25
    },
