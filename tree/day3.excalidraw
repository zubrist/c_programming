    },
    {
      "id": "4oA8MXc8edaU_Evucw7Vk",
      "type": "text",
      "x": 475.7583874773478,
      "y": 6021.418447061894,
      "width": 1045.239022450474,
      "height": 36.8011000874203,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1f",
      "roundness": null,
      "seed": 84426865,
      "version": 131,
      "versionNonce": 212861855,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779728110080,
      "link": null,
      "locked": false,
      "text": "Draw a BST with values: 60, 40, 20, 100, 50, 10, 200, 250, 235, 115, 25",
      "fontSize": 29.440880069936235,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Draw a BST with values: 60, 40, 20, 100, 50, 10, 200, 250, 235, 115, 25",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TNKmYkPHr4A2pn0dyO9a0",
      "type": "text",
      "x": 488.0648960451821,
      "y": 6127.343688326435,
      "width": 895.2505590855283,
      "height": 89.75136573061084,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "seed": 1769922623,
      "version": 164,
      "versionNonce": 758497663,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779728569212,
      "link": null,
      "locked": false,
      "text": "Will a deleted node from the Binary Search Tree regain its original position\nafter immediately reinsertion? \nExplain with suitable example",
      "fontSize": 23.933697528162888,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Will a deleted node from the Binary Search Tree regain its original position after immediately reinsertion? \nExplain with suitable example",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "EUXbu1gq0PadyPj4vfGsD",
      "type": "text",
      "x": 485.6064101194065,
      "y": 6271.661283917293,
      "width": 989.0103313305772,
      "height": 57.462171187135496,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1i",
      "roundness": null,
      "seed": 1333207825,
      "version": 204,
      "versionNonce": 840015135,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779728773482,
      "link": null,
      "locked": false,
      "text": "Whether a deleted node regains its original position upon immediate reinsertion depends \non the structure of the tree and the number of children the node had.",
      "fontSize": 22.98486847485421,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Whether a deleted node regains its original position upon immediate reinsertion depends \non the structure of the tree and the number of children the node had.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "k5WMUGQK1B7Wgbn7VakgS",
      "type": "text",
      "x": 485.0999485919923,
      "y": 6344.459488201658,
      "width": 980.9993234346514,
      "height": 215.32045968712987,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1k",
      "roundness": null,
      "seed": 641111455,
      "version": 143,
      "versionNonce": 284093407,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779728813084,
      "link": null,
      "locked": false,
      "text": "When a node is deleted from a BST, the tree often undergoes structural changes\nto maintain the BST property (where the left child is smaller and the right child\nis larger than the parent). When you reinsert that same node, it follows the\nstandard insertion algorithm, starting from the current root and moving down\nuntil it finds an empty leaf position. Because the tree's internal structure may\nhave changed during the deletion, the \"path\" to its original spot might no longer\nexist or might lead to a different location.",
      "fontSize": 24.608052535671987,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When a node is deleted from a BST, the tree often undergoes structural changes to maintain the BST property (where the left child is smaller and the right child is larger than the parent). When you reinsert that same node, it follows the standard insertion algorithm, starting from the current root and moving down until it finds an empty leaf position. Because the tree's internal structure may have changed during the deletion, the \"path\" to its original spot might no longer exist or might lead to a different location.",
      "autoResize": false,
      "lineHeight": 1.25
    },
